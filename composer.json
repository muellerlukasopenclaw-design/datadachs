{
    "name": "mueller-lukas/datadachs",
    "description": "DataDachs – Lokale Pseudonymisierung von Testdaten",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "fakerphp/faker": "^1.23",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "monolog/monolog": "^3.5",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "DataDachs\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DataDachs\\Tests\\": "tests/unit/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8080 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
