# DataDachs – Umgebungsvariablen
# Kopiere nach .env und passe an

APP_ENV=production
APP_DEBUG=false
APP_NAME=DataDachs

# Upload-Limits
MAX_UPLOAD_SIZE=50M
MAX_FILE_SIZE_MB=50

# Job-Lebenszeit in Minuten (danach werden temporäre Daten gelöscht)
JOB_TTL_MINUTES=60

# Logging: debug, info, warning, error
LOG_LEVEL=warning

# SQLite-Pfad (relativ zu storage/)
DB_PATH=storage/datadachs.db

# Optional: deterministischer Seed für reproduzierbare Pseudonymisierung
# DETERMINISTIC_SEED=

# Optional: Salt für HMAC-basierte Konsistenz (spätere Ausbaustufe)
# HMAC_SALT=

# Preserve Rules / Ausnahmewerte (JSON-Array oder kommagetrennt)
# Beispiele:
#   DATADACHS_PRESERVE_RULES='["admin","root","system","test@example.com"]'
#   DATADACHS_PRESERVE_RULES='admin,root,system,guest'
#   DATADACHS_PRESERVE_RULES='admin
# root
# system'
DATADACHS_PRESERVE_RULES='admin,root,system,guest,test,demo,support,noreply,no-reply'

# Preserve: Groß-/Kleinschreibung beachten (default: false)
DATADACHS_PRESERVE_CASE_SENSITIVE=false

# Preserve: Standard-Regeln zusätzlich laden (default: true)
DATADACHS_PRESERVE_USE_DEFAULTS=true
